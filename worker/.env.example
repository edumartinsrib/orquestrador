# Copy this file to .env before running the Python worker as a Windows service.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=default-task-queue
TEMPORAL_WORKER_IDENTITY=windows-python-worker
TEMPORAL_TLS_ENABLED=false

# Optional TLS files for private endpoints that require TLS or mTLS.
TEMPORAL_TLS_CA_FILE=
TEMPORAL_TLS_CLIENT_CERT_FILE=
TEMPORAL_TLS_CLIENT_KEY_FILE=

# Optional bearer token if Temporal Server authorization is enabled.
TEMPORAL_AUTH_TOKEN=
