# Copy this file to .env for local deploys. Do not commit real values.

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ROLE_TO_ASSUME=arn:aws:iam::123456789012:role/github-actions-temporal-deploy
EKS_CLUSTER_NAME=my-eks-cluster
AWS_ROLE_NAME=github-actions-temporal-deploy
AWS_POLICY_NAME=github-actions-temporal-deploy-policy
GITHUB_REPOSITORY=owner/repo
GITHUB_REF_PATTERN=ref:refs/heads/main

ECR_KEYCLOAK_REPOSITORY=temporal-keycloak
IMAGE_TAG=local
TEMPORAL_HELM_CHART_VERSION=1.2.0
TEMPORAL_SERVER_IMAGE_TAG=1.31.0
TEMPORAL_ADMINTOOLS_IMAGE_TAG=1.31.0
TEMPORAL_UI_IMAGE_TAG=2.49.1
KEYCLOAK_IMAGE_TAG=26.6.3

TEMPORAL_NAMESPACE=temporal
SSO_NAMESPACE=temporal-sso

TEMPORAL_DB_HOST=temporal-rds.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_NAME=temporal
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=replace-me

TEMPORAL_UI_HOST=temporal.example.com
TEMPORAL_UI_PUBLIC_URL=https://temporal.example.com
TEMPORAL_AUTH_PROVIDER_URL=https://keycloak.example.com/realms/temporal
TEMPORAL_AUTH_ISSUER_URL=https://keycloak.example.com/realms/temporal
TEMPORAL_AUTH_CLIENT_ID=temporal-ui
TEMPORAL_AUTH_CLIENT_SECRET=replace-me
TEMPORAL_INITIAL_ADMIN_USERNAME=temporal.admin
TEMPORAL_INITIAL_ADMIN_EMAIL=temporal.admin@example.com
TEMPORAL_INITIAL_ADMIN_PASSWORD=replace-me

DEPLOY_KEYCLOAK=true
KEYCLOAK_PUBLIC_HOSTNAME=keycloak.example.com
KEYCLOAK_PUBLIC_URL=https://keycloak.example.com
KEYCLOAK_DB_HOST=keycloak-rds.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=replace-me
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-me

ALB_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ALB_SCHEME=internet-facing
